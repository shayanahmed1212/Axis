rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - user can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Tasks subcollection - user can only access their own tasks
      match /tasks/{taskId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Validate task creation and updates
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.keys().hasAll(['title', 'is_completed', 'priority', 'created_at'])
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.is_completed is bool
          && request.resource.data.priority is string
          && request.resource.data.created_at is timestamp;

        allow update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.title is string
          && request.resource.data.is_completed is bool
          && request.resource.data.priority is string;
      }
    }
  }
}